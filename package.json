{
  "name": "my-turborepo",
  "private": true,
  "packageManager": "npm@11.16.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "db:generate": "npm run generate --workspace=@repo/db",
    "db:migrate": "npm run migrate --workspace=@repo/db",
    "db:seed": "npm run seed --workspace=@repo/db"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "prettier": "^3.7.4",
    "turbo": "^2.10.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "zod": "^4.4.3"
  }
}
